; Engine configuration file.
; Celadune — fresh Godot 4 platformer foundation.

config_version=5

[application]

config/name="Celadune"
run/main_scene="res://scenes/Scene1.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[addons]

; MetroidvaniaSystem (KoBeWi, MIT) is installed under addons/.
; Enable it in Project > Project Settings > Plugins to use the in-editor Map Editor.
metroidvania_system/settings_file="res://world/MetSysSettings.tres"

[autoload]

Globals="*res://scripts/Globals.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

